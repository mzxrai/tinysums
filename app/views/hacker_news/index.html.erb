<div class="w-full max-w-5xl mx-auto px-6 py-10">
  <%# Page Header %>
  <h1 class="text-2xl font-semibold mb-6 text-zinc-100">Top <%= @stories.count %> Hacker News Stories</h1>

  <%# Stories List Container %>
  <div class="bg-zinc-900 rounded-lg shadow-md overflow-hidden ring-1 ring-zinc-800">
    <ul class="divide-y divide-zinc-800">
      <% @stories.each_with_index do |story, index| %>
        <%# Individual Story Item - Added Stimulus controller, action, value, and cursor style %>
        <li class="flex py-4 px-5 hover:bg-zinc-800 transition-colors duration-150 cursor-pointer"
            data-controller="clickable-row"
            data-action="click->clickable-row#navigate"
            data-clickable-row-discussion-url-value="https://news.ycombinator.com/item?id=<%= story["id"] %>">
          <%# Story Rank %>
          <span class="text-zinc-500 font-medium w-10 text-right pr-4 pt-0 text-xs"><%= index + 1 %>.</span>
          <%# Story Content %>
          <div class="flex-1">
            <%# Story Title %>
            <h2 class="text-sm font-medium mb-1.5 leading-normal">
              <% if story["url"].present? %>
                <%# Story Link %>
                <a href="<%= story["url"] %>" class="text-zinc-100 hover:text-zinc-300 transition-colors duration-150"><%= story["title"] %></a>
                <%# Extract and display hostname if URL is external %>
                <% hostname = extract_hostname(story["url"]) %>
                <% if hostname && hostname != "news.ycombinator.com" %>
                  <span class="text-zinc-500 ml-1.5 text-xs">(<%= hostname %>)</span>
                <% end %>
              <% else %>
                <%# Link to HN comments page if no external URL %>
                <a href="https://news.ycombinator.com/item?id=<%= story["id"] %>" class="text-zinc-100 hover:text-zinc-300 transition-colors duration-150"><%= story["title"] %></a>
              <% end %>
            </h2>
            <%# Story Metadata - Use original gap-x-4 with dividers %>
            <div class="text-sm flex flex-wrap gap-x-4 items-center">
              <%# Story Score %>
              <span class="flex items-center text-emerald-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium"><%= story["score"] %></span>
              </span>

              <%# Author Link %>
              <a href="https://news.ycombinator.com/user?id=<%= story["by"] %>" class="text-zinc-500 hover:text-zinc-100 transition-colors duration-150"><%= story["by"] %></a>

              <%# Story Time (if available) %>
              <% if story["time"] %>
                <span class="text-zinc-500"><%= Time.at(story["time"]).strftime("%b %-d") %></span>
              <% end %>

              <%# Comments Link %>
              <a href="https://news.ycombinator.com/item?id=<%= story["id"] %>" class="text-zinc-500 hover:text-zinc-100 transition-colors duration-150 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.741 8.741 0 01-4.412-1.175L3.235 17.24a.5.5 0 01-.638-.64l1.205-2.964A6.96 6.96 0 014 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9a1 1 0 112 0v2a1 1 0 11-2 0V9zm4 0a1 1 0 112 0v2a1 1 0 11-2 0V9z" clip-rule="evenodd" />
                </svg>
                <%= story["descendants"] || 0 %>
              </a>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div> 